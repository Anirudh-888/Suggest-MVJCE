<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- Tells IIS to use iisnode to handle .js files -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- URL rewrite: route all requests through server.js -->
    <rewrite>
      <rules>
        <!-- Don't rewrite requests for static files in /public -->
        <rule name="StaticContent">
          <action type="Rewrite" url="public{REQUEST_URI}" />
        </rule>

        <!-- Don't rewrite requests for uploaded images -->
        <rule name="UploadedContent" stopProcessing="true">
          <match url="^uploads/(.*)" />
          <action type="Rewrite" url="uploads/{R:1}" />
        </rule>

        <!-- Route all other requests to server.js (Express) -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True" />
          </conditions>
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- iisnode configuration -->
    <iisnode
      nodeProcessCommandLine="node"
      watchedFiles="web.config;*.js"
      loggingEnabled="true"
      logDirectory="iisnode"
    />

    <!-- Allow large request bodies for image uploads -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="15728640" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
